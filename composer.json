{
    "name": "sgflores/api-response-formatter",
    "description": "A Laravel package that automatically formats API responses to a consistent structure",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "api", "response", "formatter", "middleware"],
    "authors": [
        {
            "name": "sgflores",
            "email": "floresopic@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "SgFlores\\ApiResponseFormatter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SgFlores\\ApiResponseFormatter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SgFlores\\ApiResponseFormatter\\ApiResponseFormatterServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}